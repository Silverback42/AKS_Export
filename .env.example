# AKS Export App — Umgebungsvariablen
#
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env

# SQLite-Datenbank (Pfad relativ zum Backend-Working-Directory)
DATABASE_URL=sqlite:///./data/aks_export.db

# Verzeichnis fuer Uploads, Intermediate-Dateien und Exports
DATA_DIR=./data

# Erlaubte CORS-Origins (JSON-Array)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Maximale Upload-Groesse in Bytes (Standard: 100 MB)
MAX_UPLOAD_SIZE=104857600
